var int s1
var int s2
var int s3
cav.clear
cav.add_rect s1, 10, 10, 90, 90
cav.add_rect s2, 50, 50, 130, 130
cav.add_rect s3, 90, 90, 170, 170
cav.set_style s1, "border-width:hover", 3
cav.set_style s2, "fill-color:hover", 00FFFF00H
cav.set_style s3, "fill-color", 00FF00FFH
cav.refresh

cav.to_top s2
cav.refresh

unvar s1, s2, s3