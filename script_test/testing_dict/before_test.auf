//这部分是解释器运行测试的前置测试
//用于确保输出结果的一致性
//这三行为注释不应该出现在输出中

print "This"
print " "
print "is"
print " an IO check "
print "before", " ", "testing"
println
print "这是"
println "测试前的", "IO检查"
println

println "【以下等式序成立】"
println 0, "   	=   0"
println 0.123, "   =   0.123"
println -12.5, "   =   -12.5"
println +9.2, "   =   9.2"
println -1.5e-2, "   =   -0.015"
println 07FH, "   =   127"
println 01101101B, "   =   109"
println 01101101.0001B, "   =   109.0625"
println 0F1A1BH, "   =   989723"
println 0F1A1B.5EH, "   =   989723.3671875"
println








